# Variables de entorno de ejemplo (no usar secretos reales en este archivo)

# =========================
# Core backend
# =========================
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/pique
JWT_SECRET=replace_with_a_strong_jwt_secret

# =========================
# Frontend / URLs
# =========================
# URL pública del frontend (CORS + links de auth)
FRONTEND_URL=http://localhost:3001

# URL base del backend consumida por frontend (sin /api)
NEXT_PUBLIC_API_URL=http://localhost:3000

# URL pública del sitio para metadata (og:image / json-ld)
NEXT_PUBLIC_SITE_URL=https://pique.app

# URL base del backend para links absolutos de backend (magic link fallback)
APP_BASE_URL=http://localhost:3000

# =========================
# CORS
# =========================
# Lista separada por comas. En producción definir explícitamente.
# Ejemplo: https://app.pique.app,https://admin.pique.app
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# =========================
# Auth por sesión (modo oficial)
# =========================
# Cookie sessions es el modo principal recomendado.
AUTH_ENABLE_COOKIE_SESSIONS=true

# Bearer legacy solo para compatibilidad temporal de clientes antiguos.
AUTH_ALLOW_BEARER_LEGACY=false

AUTH_ACCESS_COOKIE_NAME=tc_access
AUTH_REFRESH_COOKIE_NAME=tc_refresh
AUTH_CSRF_COOKIE_NAME=tc_csrf

# Dejar vacío para cookie host-only. Si usás subdominios, setear dominio común (ej: .pique.app)
AUTH_COOKIE_DOMAIN=

# Local: false. Producción: true.
AUTH_COOKIE_SECURE=false

# Recomendado: lax. None solo para casos cross-site explícitos y con secure=true.
AUTH_COOKIE_SAMESITE=lax

# Habilitar detrás de proxy TLS en producción (Nginx/ELB/Cloudflare)
AUTH_TRUST_PROXY=false

AUTH_ACCESS_TTL_MINUTES=15
AUTH_REFRESH_IDLE_DAYS=30
AUTH_REFRESH_ABSOLUTE_DAYS=180

# Obligatorio en producción: valor aleatorio largo (no usar este valor).
AUTH_REFRESH_PEPPER=dev-refresh-pepper

# =========================
# Rate limiting de refresh
# =========================
RATE_LIMIT_SESSION_REFRESH_WINDOW_MS=60000
RATE_LIMIT_SESSION_REFRESH_MAX=20

# =========================
# Magic link email (opcional)
# =========================
RESEND_API_KEY=replace_with_resend_api_key
EMAIL_FROM=login@auth.pique.app
MAGIC_LINK_TTL_MINUTES=15

# =========================
# Mercado Pago por club (I.3B)
# =========================
MERCADO_PAGO_ENABLED=false
MERCADO_PAGO_CLIENT_ID=
MERCADO_PAGO_CLIENT_SECRET=
MERCADO_PAGO_REDIRECT_URI=http://localhost:3000/api/integrations/mercadopago/callback
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_AUTH_URL=https://auth.mercadopago.com/authorization
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com
MERCADO_PAGO_TEST_TOKEN=false

# Cifrado de tokens de integraciones (obligatorio en producción)
INTEGRATION_SECRETS_KEY=dev-integration-secrets-key
