# Ejemplo de variables de entorno (NO subir este archivo con valores reales)

# Secreto para firmar JWTs (usar un valor largo y seguro)
JWT_SECRET=replace_with_a_strong_secret_here

# Cadena de conexión a la base de datos (Postgres ejemplo)
# Ej: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Puerto en el que corre la app (opcional)
PORT=3001

# Entorno (development | production)
NODE_ENV=development

# URL del frontend (usar para CORS)
FRONTEND_URL=http://localhost:3001

# Frontend - variables públicas
NEXT_PUBLIC_API_URL=http://localhost:3002

# Magic link (backend)
APP_BASE_URL=http://localhost:3000
RESEND_API_KEY=replace_with_resend_api_key
EMAIL_FROM=login@auth.tucancha.app
MAGIC_LINK_TTL_MINUTES=15

# URL pública del frontend (usada para og:image y JSON-LD). Ej: https://tucancha.app
# Configura esta variable en despliegues de producción.
NEXT_PUBLIC_SITE_URL=https://tucancha.app

# Opcionales
# SENTRY_DSN=

# ==========================================
# Auth sessions (Phase B rollout)
# ==========================================
# Habilita lectura de access token por cookie (dual-mode con bearer legado)
AUTH_ENABLE_COOKIE_SESSIONS=false

# Mantiene compatibilidad temporal con Authorization: Bearer
AUTH_ALLOW_BEARER_LEGACY=true

# Nombres de cookies de sesión
AUTH_ACCESS_COOKIE_NAME=tc_access
AUTH_REFRESH_COOKIE_NAME=tc_refresh

# Política de cookies (para próximas fases)
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_TRUST_PROXY=false

# Política de expiración/refresh (para próximas fases)
AUTH_ACCESS_TTL_MINUTES=15
AUTH_REFRESH_IDLE_DAYS=30
AUTH_REFRESH_ABSOLUTE_DAYS=180
AUTH_REFRESH_PEPPER=replace_with_a_strong_refresh_pepper

# Rate limit refresh endpoint
RATE_LIMIT_SESSION_REFRESH_WINDOW_MS=60000
RATE_LIMIT_SESSION_REFRESH_MAX=20
