# Variables de entorno de ejemplo (no usar secretos reales en este archivo)

# =========================
# Core backend
# =========================
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/pique
# Para Prisma Migrate usar conexión directa, sin pgbouncer.
DIRECT_DATABASE_URL=postgresql://user:password@localhost:5432/pique
# Runtime opcional con read replica / pooler.
READ_DATABASE_URL=postgresql://user:password@localhost:5432/pique
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace_with_a_strong_jwt_secret

# =========================
# Frontend / URLs
# =========================
# URL pública del frontend (CORS + links de auth)
# Piloto productivo recomendado: https://pique.ar
FRONTEND_URL=http://localhost:3001

# URL base del backend consumida por frontend.
# Recomendado para piloto/prod con un solo dominio: /api
# Piloto productivo recomendado: /api
NEXT_PUBLIC_API_URL=http://localhost:3000

# URL pública del sitio para metadata (og:image / json-ld)
NEXT_PUBLIC_SITE_URL=https://pique.ar

# URL base pública usada por backend para links absolutos y callbacks.
# Recomendado para piloto/prod con mismo dominio: https://pique.ar
# Piloto productivo recomendado: https://pique.ar
APP_BASE_URL=http://localhost:3000

# =========================
# CORS
# =========================
# Lista separada por comas. En producción definir explícitamente.
# Ejemplo piloto: https://pique.ar,https://www.pique.ar
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# =========================
# Auth por sesión (modo oficial)
# =========================
# Cookie sessions es el modo principal recomendado.
AUTH_ENABLE_COOKIE_SESSIONS=true

# Bearer legacy solo para compatibilidad temporal de clientes antiguos.
AUTH_ALLOW_BEARER_LEGACY=false

AUTH_ACCESS_COOKIE_NAME=tc_access
AUTH_REFRESH_COOKIE_NAME=tc_refresh
AUTH_CSRF_COOKIE_NAME=tc_csrf

# Dejar vacío para cookie host-only. Recomendado para piloto con mismo dominio.
# Si más adelante usás subdominios, setear dominio común (ej: .pique.ar)
AUTH_COOKIE_DOMAIN=

# Local HTTP puro: false. Smoke/staging cross-site HTTPS: true. Producción: true.
# Piloto productivo recomendado: true
AUTH_COOKIE_SECURE=false

# Recomendado: lax. Usar none solo para casos cross-site HTTPS explícitos (ej: frontend/backend en dominios distintos) y con secure=true.
# Piloto productivo recomendado: lax
AUTH_COOKIE_SAMESITE=lax

# Habilitar detrás de proxy TLS en producción (Nginx/ELB/Cloudflare)
# Piloto productivo recomendado: true
AUTH_TRUST_PROXY=false

AUTH_ACCESS_TTL_MINUTES=15
AUTH_REFRESH_IDLE_DAYS=30
AUTH_REFRESH_ABSOLUTE_DAYS=180

# Obligatorio en producción: valor aleatorio largo (no usar este valor).
AUTH_REFRESH_PEPPER=dev-refresh-pepper

# =========================
# Rate limiting de refresh
# =========================
RATE_LIMIT_SESSION_REFRESH_WINDOW_MS=60000
RATE_LIMIT_SESSION_REFRESH_MAX=20

# =========================
# Runtime opcional
# =========================
WHATSAPP_PROVIDER=wpp_http
WPP_SERVICE_URL=http://localhost:3002
ENABLE_WHATSAPP_WORKER=false
ENABLE_WHATSAPP_SEND_V2=false
ENABLE_WHATSAPP_CUSTOMER_EVENTS_V2=false
ENABLE_WHATSAPP_STAFF_EVENTS_V2=false
ENABLE_WHATSAPP_V2_DRY_RUN=false
ENABLE_WHATSAPP_CLOUD_API=false
ENABLE_WHATSAPP_WEBHOOK_PROCESSOR=false
WHATSAPP_META_GRAPH_API_BASE_URL=https://graph.facebook.com
WHATSAPP_META_GRAPH_API_VERSION=v19.0
WHATSAPP_META_REQUEST_TIMEOUT_MS=10000
WHATSAPP_META_RECIPIENT_ALLOWLIST=
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_META_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_META_WABA_ID=
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_BUSINESS_PHONE=
WHATSAPP_META_TOKEN_SECRET_REF=WHATSAPP_META_ACCESS_TOKEN
WHATSAPP_SENDER_DISPLAY_NAME=Pique
ENABLE_OUTBOX=true
ENABLE_READ_MODELS=true

# =========================
# Magic link email (opcional)
# =========================
RESEND_API_KEY=replace_with_resend_api_key
EMAIL_FROM=login@auth.pique.ar
MAGIC_LINK_TTL_MINUTES=15

# =========================
# Google OAuth (opcional)
# =========================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=
APPLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/apple/callback
APPLE_OAUTH_SCOPES=name email
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/facebook/callback
FACEBOOK_OAUTH_SCOPES=email public_profile
FACEBOOK_OAUTH_GRAPH_VERSION=v19.0

# =========================
# Mercado Pago por club (I.3B)
# =========================
MERCADO_PAGO_ENABLED=false
MERCADO_PAGO_CLIENT_ID=
MERCADO_PAGO_CLIENT_SECRET=
# Piloto productivo recomendado si MP se activa:
# MERCADO_PAGO_REDIRECT_URI=https://pique.ar/api/integrations/mercadopago/callback
MERCADO_PAGO_REDIRECT_URI=http://localhost:3000/api/integrations/mercadopago/callback
# El webhook real debe apuntar a:
# https://pique.ar/api/webhooks/mercadopago
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_AUTH_URL=https://auth.mercadopago.com/authorization
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com
MERCADO_PAGO_TEST_TOKEN=false

# Cifrado de tokens de integraciones (obligatorio en producción)
INTEGRATION_SECRETS_KEY=dev-integration-secrets-key

# =========================
# ARCA / AFIP (facturacion electronica)
# =========================
# Kill switch global. false = no se crean facturas ni se llama a ARCA aunque el club tenga
# facturacionHabilitada=true en DB. Setear true solo cuando el club tiene certificado cargado.
ARCA_ENABLED=false

# Worker asíncrono de emisión. false = las facturas se encolan pero no se procesan.
# Activar una vez que el certificado esté cargado y homologación aprobada.
ENABLE_ARCA_WORKER=false

# URLs de los servicios SOAP de AFIP (no cambiar salvo instrucción de ARCA)
ARCA_WSAA_SERVICE=wsfe
ARCA_WSAA_URL_TEST=https://wsaahomo.afip.gov.ar/ws/services/LoginCms
ARCA_WSAA_URL_PROD=https://wsaa.afip.gov.ar/ws/services/LoginCms
ARCA_WSFE_URL_TEST=https://wswhomo.afip.gov.ar/wsfev1/service.asmx
ARCA_WSFE_URL_PROD=https://wsfev1.afip.gov.ar/wsfev1/service.asmx
ARCA_TIMEOUT_MS=20000

# Intervalo del chequeo de vencimiento de certificados (default: 1 hora)
CERT_EXPIRY_CHECK_INTERVAL_MS=3600000

# =========================
# S3 / almacenamiento de comprobantes (opcional)
# =========================
# Sin estas vars, los comprobantes HTML no se persisten pero el CAE se procesa igual.
# Compatible con AWS S3, MinIO, Backblaze B2, Cloudflare R2 u otro S3-compatible.
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Para S3-compatible (MinIO, etc): URL base del endpoint. Dejar vacío para AWS nativo.
S3_ENDPOINT=
# URL pública base para construir links de descarga (ej: https://cdn.pique.ar)
S3_PUBLIC_BASE_URL=
# Para path-style buckets (MinIO local): true. Para AWS virtual-hosted: false.
S3_FORCE_PATH_STYLE=true

# =========================
# Seeds / bootstrap
# =========================
# En producción, el seed queda bloqueado salvo que se habilite explícitamente.
ALLOW_SEED=false
