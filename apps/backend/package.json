{
  "name": "sistema-turnos-backend",
  "version": "1.0.0",
  "description": "Backend para sistema de reservas de canchas",
  "main": "src/index.ts",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "ts-node src/scripts/prismaGenerateSafe.ts && tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "start": "node dist/index.js",
    "start:all": "PROCESS_ROLE=all node dist/index.js",
    "start:api": "PROCESS_ROLE=api node dist/index.js",
    "start:worker": "PROCESS_ROLE=worker node dist/index.js",
    "start:scheduler": "PROCESS_ROLE=scheduler node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:generate:safe": "ts-node src/scripts/prismaGenerateSafe.ts",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:data:migrate:activity-club": "ts-node prisma/data-migration-activitytype-club.ts",
    "migrate:financial-system": "ts-node src/scripts/migrateFinancialSystem.ts",
    "preflight:stabilization": "ts-node src/scripts/preflightStabilization.ts",
    "fix:stabilization-data": "ts-node src/scripts/fixStabilizationData.ts",
    "rebuild:read-models": "ts-node src/scripts/rebuildReadModels.ts",
    "db:ensure-partitions": "ts-node src/scripts/ensureFuturePartitions.ts",
    "smoke:release": "ts-node src/scripts/smokeRelease.ts",
    "phones:backfill": "ts-node src/scripts/backfillPhoneCanonical.ts",
    "db:setup": "bash setup-db-simple.sh",
    "db:setup:win": "setup-db.bat",
    "db:reset": "docker rm -f sistema-postgres && npm run db:setup",
    "db:push": "prisma db push --accept-data-loss",
    "db:seed": "prisma db seed",
    "db:backup": "bash ../../scripts/backup-db.sh",
    "test": "npm run prisma:generate && node --test -r ts-node/register tests/*.test.ts tests/**/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.12.0",
    "nodemon": "^3.1.11",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^5.22.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dayjs": "^1.11.9",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "redis": "^5.11.0",
    "resend": "^4.8.0",
    "whatsapp-web.js": "^1.20.0",
    "zod": "^3.22.4"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
