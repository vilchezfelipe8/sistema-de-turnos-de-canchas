generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

//
// ENUMS
//

enum Role {
  ADMIN
  MEMBER
  GUEST
}

enum MembershipRole {
  OWNER
  ADMIN
  STAFF
  CUSTOMER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum BookingParticipantStatus {
  INVITED
  JOINED
  DECLINED
  LEFT
  REMOVED
}

enum BookingParticipantRole {
  ORGANIZER
  PARTICIPANT
}

enum BookingConfirmationMode {
  AUTOMATIC
  MANUAL
  DEPOSIT_REQUIRED
}

enum ChargeMode {
  INDIVIDUAL
  SHARED
}

enum ClubOperationalStatus {
  OPEN
  TEMPORARY_CLOSED
  PERMANENTLY_CLOSED
}

enum ScheduleMode {
  FIXED
  RANGE
}

enum FixedBookingStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum AccountSource {
  BOOKING
  BAR
  TABLE
  MANUAL
  CLASS_PASS
  CLASS_ENROLLMENT
}

enum AccountStatus {
  OPEN
  CLOSED
}

enum AccountItemType {
  BOOKING
  PRODUCT
  SERVICE
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  OTHER
}

enum PaymentSource {
  POS
  ONLINE
  BACKOFFICE
}

enum PaymentProvider {
  MERCADO_PAGO
}

enum PaymentIntegrationStatus {
  CONNECTED
  DISCONNECTED
  EXPIRED
  ERROR
}

enum OnlinePaymentAttemptStatus {
  CREATED
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  ERROR
}


enum FiscalCondition {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTO
  EXENTO
  CONSUMIDOR_FINAL
  OTRO
}

enum FiscalProvider {
  ARCA
  NONE
  OTRO
}

enum FiscalMode {
  OBLIGATORIA
  OPCIONAL
  DESHABILITADA
}

enum FiscalVoucherKind {
  INVOICE
  CREDIT_NOTE
}

enum FiscalVoucherStatus {
  PENDING
  QUEUED
  PROCESSING
  APPROVED
  APPROVED_WITH_OBSERVATIONS
  REJECTED
  TECHNICAL_ERROR
  CANCELLED
}

enum FiscalOriginType {
  BOOKING
  ACCOUNT
  ACCOUNT_ITEM
  MANUAL
  REFUND
}

enum FiscalItemType {
  PRODUCT
  SERVICE
}

enum FiscalIncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  IGNORED
}

enum FiscalVoucherClass {
  A
  B
  C
}

enum FiscalVoucherVariant {
  STANDARD
  PAGO_EN_CBU_INFORMADA
  OPERACION_SUJETA_A_RETENCION
}

enum PaymentChannel {
  AUTO
  CASH_DRAWER
  BANK_ACCOUNT
  CARD_TERMINAL
  VIRTUAL_WALLET
  OTHER
}

enum CashMovementMethod {
  CASH
  TRANSFER
  CARD
}

enum LedgerEntryType {
  ACCOUNT_ITEM
  PAYMENT
  REFUND
  ADJUSTMENT
}

enum LedgerReferenceType {
  ACCOUNT
  ACCOUNT_ITEM
  PAYMENT
  REFUND
  BOOKING
  CLASS_PASS
  CLASS_ENROLLMENT
  MANUAL
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum LedgerAccount {
  CASH
  BANK
  CARD_CLEARING
  ONLINE_GATEWAY
  ACCOUNTS_RECEIVABLE
  BOOKING_REVENUE
  BAR_REVENUE
  ACADEMY_REVENUE
  ADJUSTMENTS
  EXPENSE
}

enum CashShiftStatus {
  OPEN
  CLOSED
}

enum CashMovementPosType {
  PAYMENT_IN
  REFUND
  WITHDRAW
  DEPOSIT
}

enum OutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  READY_TO_EXECUTE
  EXECUTED
  FAILED
  CANCELLED
}

enum RefundExecutionMethod {
  CASH
  TRANSFER
  CARD_REVERSAL
  CREDIT_NOTE
  OTHER
}

enum RefundReasonType {
  FULL
  PARTIAL_COMMERCIAL
  PARTIAL_SERVICE_FAILURE
  PARTIAL_PRICING_ERROR
  OTHER
}

enum DiscountScope {
  BOOKING
  PRODUCT
  SERVICE
  ALL
}

enum DiscountAmountType {
  PERCENT
  FIXED
}

enum DiscountApplyMode {
  INCLUDE_ONLY
  EXCLUDE_LIST
}

enum ClubReviewStatus {
  PUBLISHED
  HIDDEN
}

enum AuthSessionStatus {
  ACTIVE
  ROTATED
  REVOKED
  EXPIRED
}

enum ClientRelationshipType {
  PARENT
  GUARDIAN
  CHILD
  PAYER
  FAMILY_MEMBER
  EMERGENCY_CONTACT
  OTHER
}

enum ClassSessionVisibility {
  PUBLIC
  PRIVATE
}

enum ClassSessionType {
  INDIVIDUAL
  GROUP
}

enum ClassSessionStatus {
  DRAFT
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ClassEnrollmentStatus {
  ENROLLED
  WAITLISTED
  CANCELLED
}

enum ClassAttendanceStatus {
  PENDING
  ATTENDED
  ABSENT
  NO_SHOW
  CANCELLED_ON_TIME
  CANCELLED_LATE
}

enum ClassEnrollmentPaymentStatus {
  UNPAID
  PARTIAL
  PAID
  COVERED_BY_CREDIT
  REFUNDED
}

enum ClassPassStatus {
  ACTIVE
  EXPIRED
  DEPLETED
  CANCELLED
}

enum ClassCreditUsageReason {
  ATTENDANCE
  LATE_CANCEL
  NO_SHOW
  MANUAL_ADJUSTMENT
  REFUND_REVERSAL
}

//
// MODELOS
//

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  firstName     String
  lastName      String
  phoneNumber   String
  emailVerifiedAt DateTime?    @db.Timestamptz(3)
  lastLoginAt    DateTime?     @db.Timestamptz(3)
  role          Role           @default(MEMBER)
  dni       String?

  bookings      Booking[]
  bookingHistoryEntries BookingHistoryEntry[] @relation("BookingHistoryActor")
  bookingParticipants BookingParticipant[]
  bookingParticipantInvitationsSent BookingParticipant[] @relation("BookingParticipantInvitedBy")
  paymentIntegrationsConnected ClubPaymentIntegration[] @relation("ClubPaymentIntegrationConnectedBy")
  paymentProviderOAuthStates PaymentProviderOAuthState[]
  onlinePaymentAttempts OnlinePaymentAttempt[]
  clients       Client[]
  fixedBookings FixedBooking[]
  memberships   Membership[]
  notifications Notification[]
  auditLogs     AuditLog[]
  cashShiftsOpened CashShift[] @relation("CashShiftOpenedBy")
  cashShiftsClosed CashShift[] @relation("CashShiftClosedBy")
  ledgerEntries LedgerEntry[]
  ledgerTransactionsCreated LedgerTransaction[]
  cashMovementsCreated CashMovement[]
  refundsCreated Refund[]
  refundsApproved Refund[] @relation("RefundApprovedBy")
  refundsExecuted Refund[] @relation("RefundExecutedBy")
  refundsCancelled Refund[] @relation("RefundCancelledBy")
  clientDiscountAssignmentsCreated ClientDiscountAssignment[]
  accountItemDiscountsApplied AccountItemDiscount[]
  clubReviews ClubReview[]
  clubFavorites ClubFavorite[]
  duplicateIncidents ClientDuplicateIncident[] @relation("DuplicateIncidentUser")
  duplicateIncidentsResolved ClientDuplicateIncident[] @relation("DuplicateIncidentResolvedBy")
  sessions      AuthSession[]
  teacherProfiles Teacher[]
  academyClassSessionsCreated ClassSession[] @relation("ClassSessionCreatedByUser")
  academyStudentEnrollments ClassEnrollment[] @relation("ClassEnrollmentStudentUser")
  academyClassEnrollmentsCreated ClassEnrollment[] @relation("ClassEnrollmentCreatedByUser")
  academyOwnedClassPasses ClassPass[] @relation("ClassPassOwnerUser")
  academyBeneficiaryClassPasses ClassPass[] @relation("ClassPassBeneficiaryUser")
  academyClassPassesCreated ClassPass[] @relation("ClassPassCreatedByUser")
  academyClassCreditUsagesCreated ClassCreditUsage[] @relation("ClassCreditUsageCreatedByUser")
  fiscalIncidentsAssigned FiscalIncident[]
}

model MagicLoginToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime  @db.Timestamptz(3)
  consumedAt DateTime? @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  ip        String?
  userAgent String?

  @@index([email])
  @@index([expiresAt])
}

model AuthSession {
  id                String            @id @default(cuid())
  userId            Int
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash  String            @unique
  familyId          String
  parentSessionId   String?
  status            AuthSessionStatus @default(ACTIVE)

  ip                String?
  userAgent         String?
  deviceLabel       String?

  createdAt         DateTime          @default(now()) @db.Timestamptz(3)
  lastSeenAt        DateTime          @default(now()) @db.Timestamptz(3)
  rotatedAt         DateTime?         @db.Timestamptz(3)
  revokedAt         DateTime?         @db.Timestamptz(3)
  expiresAt         DateTime          @db.Timestamptz(3)
  absoluteExpiresAt DateTime          @db.Timestamptz(3)

  @@index([userId, status])
  @@index([familyId])
  @@index([expiresAt])
}

model Club {
  id            Int       @id @default(autoincrement())
  slug          String    @unique
  name          String
  addressLine   String
  city          String
  province      String
  country       String

  locationId    Int?
  location      Location? @relation(fields: [locationId], references: [id])

  contactInfo   String
  phone         String?
  logoUrl       String?
  clubImageUrl  String?
  instagramUrl  String?
  facebookUrl   String?
  websiteUrl    String?
  description   String?

  createdAt     DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(3)

  // Configuración técnica/operativa movida a ClubSettings
  settings      ClubSettings? 

  // Relaciones
  courts        Court[]
  activities    ActivityType[]
  clients       Client[]
  bookings      Booking[]
  products      Product[]
  servicesCatalog ClubServiceCatalog[]
  cashMovements CashMovement[]
  memberships   Membership[]
  fixedBookings FixedBooking[]
  accounts      Account[]
  notifications Notification[]
  courtPriceRules CourtPriceRule[]
  auditLogs     AuditLog[]
  events        Event[]
  outboxMessages OutboxMessage[]
  cashRegisters CashRegister[]
  cashShifts    CashShift[]
  ledgerEntries LedgerEntry[]
  ledgerTransactions LedgerTransaction[]
  refunds       Refund[]
  discountPolicies DiscountPolicy[]
  clientDiscountAssignments ClientDiscountAssignment[]
  accountItemDiscounts AccountItemDiscount[]
  reviews       ClubReview[]
  favorites     ClubFavorite[]
  duplicateIncidents ClientDuplicateIncident[]
  paymentIntegrations ClubPaymentIntegration[]
  paymentProviderOAuthStates PaymentProviderOAuthState[]
  onlinePaymentAttempts OnlinePaymentAttempt[]
  configuracionFiscal ConfiguracionFiscal?
  puntosDeVentaFiscales PuntoDeVentaFiscal[]
  facturasFiscales Factura[]
  fiscalIncidents FiscalIncident[]
  bookingHistoryEntries BookingHistoryEntry[]
  teachers      Teacher[]
  clientRelationships ClientRelationship[]
  classSessions ClassSession[]
  classEnrollments ClassEnrollment[]
  classPasses ClassPass[]
  classCreditUsages ClassCreditUsage[]
}

model ClubFavorite {
  id        String   @id @default(cuid())
  clubId    Int
  userId    Int
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  club      Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId, createdAt])
}

model Membership {
  id     String         @id @default(cuid())
  userId Int
  clubId Int
  role   MembershipRole

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, clubId])
  @@index([clubId])
  @@index([userId])
}

model ClubPaymentIntegration {
  id              String                   @id @default(cuid())
  clubId          Int
  club            Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  provider        PaymentProvider
  status          PaymentIntegrationStatus @default(DISCONNECTED)
  accessTokenEnc  String?
  refreshTokenEnc String?
  publicKey       String?
  externalUserId  String?
  expiresAt       DateTime?                @db.Timestamptz(3)
  connectedById   Int?
  connectedBy     User?                    @relation("ClubPaymentIntegrationConnectedBy", fields: [connectedById], references: [id], onDelete: SetNull)
  disconnectedAt  DateTime?                @db.Timestamptz(3)
  createdAt       DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime                 @updatedAt @db.Timestamptz(3)

  onlinePaymentAttempts OnlinePaymentAttempt[]
  oauthStates          PaymentProviderOAuthState[]

  @@unique([clubId, provider])
  @@index([provider, status])
}

model PaymentProviderOAuthState {
  id            String          @id @default(cuid())
  clubId        Int
  club          Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  provider      PaymentProvider
  userId        Int
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  integrationId String?
  integration   ClubPaymentIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  nonce         String          @unique
  expiresAt     DateTime        @db.Timestamptz(3)
  consumedAt    DateTime?       @db.Timestamptz(3)
  createdAt     DateTime        @default(now()) @db.Timestamptz(3)

  @@index([clubId, provider, expiresAt])
}

model Location {
  id        Int      @id @default(autoincrement())
  city      String
  province  String
  country   String

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  clubs     Club[]

  @@unique([city, province, country])
}

model Court {
  id                 Int     @id @default(autoincrement())
  name               String
  isIndoor           Boolean
  surface            String
  isUnderMaintenance Boolean @default(false)
  price              Decimal @default(0) @db.Decimal(10, 2)

  activityTypeId Int?
  activityType   ActivityType? @relation(fields: [activityTypeId], references: [id])

  clubId Int
  club   Club @relation(fields: [clubId], references: [id])

  bookings      Booking[]
  fixedBookings FixedBooking[]
  priceRules    CourtPriceRule[]
  classSessions ClassSession[]

  @@index([clubId])
}

model CourtPriceRule {
  id           Int      @id @default(autoincrement())

  courtId      Int
  court        Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  clubId       Int
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  dayOfWeek    Int
  startMinutes Int
  endMinutes   Int
  price        Decimal @db.Decimal(10, 2)

  createdAt    DateTime @default(now()) @db.Timestamptz(3)

  @@index([courtId])
  @@index([clubId])
  @@index([courtId, dayOfWeek])
}

model ActivityType {
  id                     Int            @id @default(autoincrement())
  name                   String
  description            String
  defaultDurationMinutes Int

  clubId                 Int
  club                   Club           @relation(fields: [clubId], references: [id])

  scheduleMode           ScheduleMode   @default(FIXED)
  scheduleOpenTime       String?
  scheduleCloseTime      String?
  scheduleIntervalMinutes Int?
  scheduleWindows        Json?
  scheduleDurations      Json?
  scheduleFixedSlots     Json?
  scheduleExceptions     ActivityScheduleException[]

  courts                 Court[]
  bookings               Booking[]
  fixedBookings          FixedBooking[]
  discountTargets        DiscountPolicyTarget[]
  classSessions          ClassSession[]
  classPasses            ClassPass[]

  @@index([clubId])
}

model ActivityScheduleException {
  id                      Int          @id @default(autoincrement())
  activityTypeId          Int
  activityType            ActivityType @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)
  localDate               DateTime     @db.Date

  // Si está cerrado, esta excepción bloquea todo el día para la actividad.
  isClosed                Boolean      @default(false)

  // Configuración opcional para reemplazar agenda base de la actividad en ese día.
  scheduleMode            ScheduleMode?
  scheduleOpenTime        String?
  scheduleCloseTime       String?
  scheduleIntervalMinutes Int?
  scheduleWindows         Json?
  scheduleDurations       Json?
  scheduleFixedSlots      Json?

  createdAt               DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime     @updatedAt @db.Timestamptz(3)

  @@unique([activityTypeId, localDate])
  @@index([localDate])
}

model Client {
  id        String   @id @default(cuid())
  clubId    Int
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  name      String
  dni       String?
  phone     String?
  email     String?
  isProfessor Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
  bookingParticipants BookingParticipant[]
  fixedBookings FixedBooking[]
  discountAssignments ClientDiscountAssignment[]
  accountItemDiscounts AccountItemDiscount[]
  duplicateIncidentsPrimary ClientDuplicateIncident[] @relation("DuplicateIncidentPrimaryClient")
  duplicateIncidentsResolvedTarget ClientDuplicateIncident[] @relation("DuplicateIncidentResolvedClient")
  accounts      Account[]
  teacherProfiles Teacher[]
  outgoingClientRelationships ClientRelationship[] @relation("ClientRelationshipFromClient")
  incomingClientRelationships ClientRelationship[] @relation("ClientRelationshipToClient")
  studentClassEnrollments ClassEnrollment[] @relation("ClassEnrollmentStudentClient")
  billingResponsibleClassEnrollments ClassEnrollment[] @relation("ClassEnrollmentBillingResponsibleClient")
  ownedClassPasses ClassPass[] @relation("ClassPassOwnerClient")
  beneficiaryClassPasses ClassPass[] @relation("ClassPassBeneficiaryClient")

  @@index([clubId])
  @@index([userId])
  @@index([clubId, email])
  @@index([clubId, phone])
  @@index([clubId, dni])
  @@unique([clubId, userId])
}

enum ClientDuplicateIncidentStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model ClientDuplicateIncident {
  id        String   @id @default(cuid())
  clubId    Int
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  userId    Int?
  user      User?    @relation("DuplicateIncidentUser", fields: [userId], references: [id], onDelete: SetNull)

  status    ClientDuplicateIncidentStatus @default(OPEN)
  reasonType String
  sourceType String
  dedupeKey String?

  primaryClientId String?
  primaryClient   Client? @relation("DuplicateIncidentPrimaryClient", fields: [primaryClientId], references: [id], onDelete: SetNull)

  candidateClientIds Json
  payload            Json?

  resolutionType     String?
  resolutionNotes    String?
  resolvedClientId   String?
  resolvedClient     Client? @relation("DuplicateIncidentResolvedClient", fields: [resolvedClientId], references: [id], onDelete: SetNull)
  resolvedByUserId   Int?
  resolvedByUser     User?   @relation("DuplicateIncidentResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  resolvedAt         DateTime? @db.Timestamptz(3)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([clubId, status, createdAt])
  @@index([clubId, dedupeKey, status])
}

model Teacher {
  id        String   @id @default(cuid())
  clubId    Int
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  displayName String
  email       String?
  phone       String?
  isInternal  Boolean @default(false)
  isActive    Boolean @default(true)
  specialtiesJson Json?
  notes       String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  classSessions ClassSession[]
  classPasses   ClassPass[]

  @@index([clubId, isActive, displayName])
  @@index([clientId])
  @@index([userId])
  @@unique([clubId, clientId])
  @@unique([clubId, userId])
}

model ClientRelationship {
  id        String @id @default(cuid())
  clubId    Int
  club      Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  fromClientId String
  fromClient   Client @relation("ClientRelationshipFromClient", fields: [fromClientId], references: [id], onDelete: Cascade)
  toClientId   String
  toClient     Client @relation("ClientRelationshipToClient", fields: [toClientId], references: [id], onDelete: Cascade)

  relationshipType ClientRelationshipType
  canPayFor            Boolean @default(false)
  canManageEnrollments Boolean @default(false)
  canViewSchedule      Boolean @default(false)
  canCancelClass       Boolean @default(false)
  canViewPayments      Boolean @default(false)
  notes                String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([clubId, fromClientId])
  @@index([clubId, toClientId])
  @@index([clubId, relationshipType])
  @@unique([clubId, fromClientId, toClientId, relationshipType])
}

model ClassSession {
  id        String @id @default(cuid())
  clubId    Int
  club      Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  visibility ClassSessionVisibility
  classType  ClassSessionType

  activityTypeId Int?
  activityType   ActivityType? @relation(fields: [activityTypeId], references: [id], onDelete: SetNull)

  courtId Int?
  court   Court? @relation(fields: [courtId], references: [id], onDelete: SetNull)

  startsAt        DateTime @db.Timestamptz(3)
  endsAt          DateTime @db.Timestamptz(3)
  durationMinutes Int
  capacity        Int
  pricePerStudent Decimal? @db.Decimal(10, 2)
  status          ClassSessionStatus @default(SCHEDULED)
  level           String?
  description     String?
  requiresApproval Boolean @default(false)
  requiresPaymentToEnroll Boolean @default(false)

  createdByUserId Int
  createdByUser   User @relation("ClassSessionCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)

  metadataJson Json?
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)

  enrollments ClassEnrollment[]

  @@index([clubId, startsAt])
  @@index([clubId, status])
  @@index([clubId, teacherId, startsAt])
  @@index([clubId, courtId, startsAt])
  @@index([clubId, visibility, classType])
}

model ClassEnrollment {
  id        String @id @default(cuid())
  clubId    Int
  club      Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  classSessionId String
  classSession   ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  studentClientId String
  studentClient   Client @relation("ClassEnrollmentStudentClient", fields: [studentClientId], references: [id], onDelete: Restrict)

  studentUserId Int?
  studentUser   User? @relation("ClassEnrollmentStudentUser", fields: [studentUserId], references: [id], onDelete: SetNull)

  billingResponsibleClientId String?
  billingResponsibleClient   Client? @relation("ClassEnrollmentBillingResponsibleClient", fields: [billingResponsibleClientId], references: [id], onDelete: SetNull)

  snapshotName  String
  snapshotEmail String?
  snapshotPhone String?

  priceAtEnrollment Decimal @default(0) @db.Decimal(10, 2)
  paidAmount        Decimal @default(0) @db.Decimal(10, 2)
  enrollmentStatus  ClassEnrollmentStatus @default(ENROLLED)
  attendanceStatus  ClassAttendanceStatus @default(PENDING)
  paymentStatus     ClassEnrollmentPaymentStatus @default(UNPAID)

  cancelledAt DateTime? @db.Timestamptz(3)
  attendedAt  DateTime? @db.Timestamptz(3)
  notes       String?

  createdByUserId Int
  createdByUser   User @relation("ClassEnrollmentCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  creditUsages ClassCreditUsage[]

  @@index([clubId, classSessionId])
  @@index([clubId, studentClientId])
  @@index([clubId, billingResponsibleClientId])
  @@index([classSessionId, enrollmentStatus])
